# Google Sheets data source (public gviz CSV — no API key needed)
VITE_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/gviz/tq?tqx=out:csv

# Gemini API key — get one at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Gemini model (default: gemini-2.5-flash)
VITE_GEMINI_MODEL=gemini-2.5-flash
